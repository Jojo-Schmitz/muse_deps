+PaError PaAsio_GetDeviceCurrentSampleRate( PaDeviceIndex device, double *currentSampleRate )
+{
+    PaError result;
+    PaUtilHostApiRepresentation *hostApi;
+    PaDeviceIndex hostApiDevice;
+    PaAsioHostApiRepresentation *asioHostApi;
+    PaWinUtilComInitializationResult comInitializationResult;
+    ASIOSampleRate sampleRate;
+
+    if( !currentSampleRate )
+        return paBadBufferPtr;
+
+    *currentSampleRate = 0;
+
+    /* initialize COM again here, we might be in another thread */
+    result = PaWinUtil_CoInitialize( paASIO, &comInitializationResult );
+    if( result != paNoError )
+        return result;
+
+    result = PaUtil_GetHostApiRepresentation( &hostApi, paASIO );
+    if( result == paNoError )
+        result = PaUtil_DeviceIndexToHostApiDeviceIndex( &hostApiDevice, device, hostApi );
+
+    if( result == paNoError )
+    {
+        asioHostApi = (PaAsioHostApiRepresentation*)hostApi;
+
+        if( asioHostApi->openAsioDeviceIndex == hostApiDevice )
+        {
+            if( ASIOGetSampleRate( &sampleRate ) == ASE_OK && sampleRate > 0 )
+                *currentSampleRate = sampleRate;
+            else
+                result = paUnanticipatedHostError;
+        }
+        else if( asioHostApi->openAsioDeviceIndex != paNoDevice )
+        {
+            result = paDeviceUnavailable;
+        }
+        else
+        {
+            /* padded, some drivers write over the data given to them */
+            union _tag_local {
+                PaAsioDriverInfo info;
+                char _padding[4096];
+            } paAsioDriver;
+
+            result = LoadAsioDriver( asioHostApi, hostApi->deviceInfos[hostApiDevice]->name,
+                    &paAsioDriver.info, asioHostApi->systemSpecific );
+            if( result == paNoError )
+            {
+                /* refresh the lazily initialized device info */
+                UpdateAsioDeviceInfoFromLoadedDriver( asioHostApi, hostApiDevice, &paAsioDriver.info );
+
+                if( ASIOGetSampleRate( &sampleRate ) == ASE_OK && sampleRate > 0 )
+                    *currentSampleRate = sampleRate;
+                else
+                    result = paUnanticipatedHostError;
+
+                UnloadAsioDriver();
+            }
+        }
+    }
+
+    PaWinUtil_CoUninitialize( paASIO, &comInitializationResult );
+
+    return result;
+}
