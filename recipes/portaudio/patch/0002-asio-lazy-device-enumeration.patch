+PaError PaAsio_SetCachedDeviceInfo( PaDeviceIndex device,
+        int maxInputChannels, int maxOutputChannels, double defaultSampleRate )
+{
+    PaError result;
+    PaUtilHostApiRepresentation *hostApi;
+    PaDeviceIndex hostApiDevice;
+    PaDeviceInfo *deviceInfo;
+
+    if( maxInputChannels < 0 || maxOutputChannels < 0 )
+        return paInvalidChannelCount;
+
+    if( !(defaultSampleRate > 0) )
+        return paInvalidSampleRate;
+
+    result = PaUtil_GetHostApiRepresentation( &hostApi, paASIO );
+    if( result != paNoError )
+        return result;
+
+    result = PaUtil_DeviceIndexToHostApiDeviceIndex( &hostApiDevice, device, hostApi );
+    if( result != paNoError )
+        return result;
+
+    deviceInfo = hostApi->deviceInfos[hostApiDevice];
+
+    deviceInfo->maxInputChannels = maxInputChannels;
+    deviceInfo->maxOutputChannels = maxOutputChannels;
+    deviceInfo->defaultSampleRate = defaultSampleRate;
+
+    return paNoError;
+}
